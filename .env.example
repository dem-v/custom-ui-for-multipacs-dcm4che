# ============================================================================
# xrayservice configuration
# Copy this file to `.env` and fill in your own values.
#   cp .env.example .env
# (docker compose reads `.env` automatically from this directory)
# ============================================================================

# OHIF base image tag to build from: latest-beta (default, v3.13 line) or latest (stable).
OHIF_TAG=latest-beta

# Host running the 4 dcm4chee PACS (IP or hostname reachable from this machine).
PACS_HOST=pacs.example.local

# Scheme of the DICOMweb ports below. Ports 8443-8446 look like HTTPS, so this
# defaults to https (self-signed certs are tolerated). If they are actually
# plain HTTP, set this to: http
PACS_SCHEME=https

# DICOMweb HTTP(S) port for each PACS.
# (The DIMSE ports 11112-11115 are for C-STORE/C-FIND and are NOT used by OHIF.)
#   XRAYPACS  -> DIMSE 11112 -> DICOMweb 8443
#   CTPACS    -> DIMSE 11113 -> DICOMweb 8444
#   ANGIOPACS -> DIMSE 11114 -> DICOMweb 8445
#   USPACS    -> DIMSE 11115 -> DICOMweb 8446
PACS_PORT_XRAY=8443
PACS_PORT_CT=8444
PACS_PORT_ANGIO=8445
PACS_PORT_US=8446

# Host port the viewer is published on. Point the LAN users and the Cloudflare
# tunnel at this port. Change to e.g. 8088 if port 80 is already in use.
HTTP_PORT=80

# Only needed if you uncomment the in-stack cloudflared service in compose.
# CLOUDFLARE_TUNNEL_TOKEN=
